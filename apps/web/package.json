{
  "name": "@guerillaglass/web",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "bunx convex dev --once && concurrently -r \"bun run dev:web\" \"bun run dev:convex\"",
    "dev:web": "vite dev --port 3000",
    "dev:convex": "bunx convex dev",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "vite build && bun run typecheck",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.10.10",
    "@convex-dev/react-query": "^0.1.0",
    "@fontsource-variable/space-grotesk": "^5.2.8",
    "@fontsource/space-mono": "^5.2.8",
    "@guerillaglass/ui": "workspace:*",
    "@react-three/fiber": "^9.5.0",
    "@shadergradient/react": "^2.4.20",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.161.3",
    "@tanstack/react-router-ssr-query": "^1.161.3",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.161.3",
    "better-auth": "1.4.9",
    "camera-controls": "^3.1.2",
    "convex": "^1.31.7",
    "lucide-react": "^0.576.0",
    "motion": "^12.23.24",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2",
    "three-stdlib": "^2.36.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^20.19.24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
